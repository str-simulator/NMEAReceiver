<UserControl x:Class="NMEAReceiver.Views.Panels.DiagnosticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="220"
             d:DesignWidth="1280"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Column="0" Header="Selected Channel – Received Sentences">
            <TextBox x:Name="RawSentenceBox"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Style="{StaticResource MonoTextBoxStyle}"
                     Text="{Binding RawSentence, Mode=OneWay}"
                     TextChanged="RawSentenceBox_TextChanged"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" />
        </GroupBox>

        <GroupBox Grid.Column="2" Header="Log">
            <TextBox x:Name="LogBox"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Style="{StaticResource MonoTextBoxStyle}"
                     Text="{Binding LogText, Mode=OneWay}"
                     TextChanged="LogBox_TextChanged"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" />
        </GroupBox>
    </Grid>
</UserControl>
