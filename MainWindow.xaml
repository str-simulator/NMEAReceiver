<Window x:Class="NMEAReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NMEA Receiver"
        Width="1500"
        Height="1000"
        MinWidth="1080"
        MinHeight="700"
        Background="{StaticResource AppBackgroundBrush}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0"
                        Margin="0,0,0,12"
                        Content="{Binding ChannelSetup}" />

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <ContentControl Grid.Column="0" Content="{Binding ChannelsTable}" />
            <ContentControl Grid.Column="2" Content="{Binding Snapshot}" />
        </Grid>

        <ContentControl Grid.Row="2" Content="{Binding Diagnostic}" />
    </Grid>
</Window>
